# Database
POSTGRES_USER=juflow
POSTGRES_PASSWORD=juflow_dev
POSTGRES_DB=juflow
DATABASE_URL=postgresql+asyncpg://juflow:juflow_dev@postgres:5432/juflow

# Redis
REDIS_URL=redis://redis:6379/0

# Auth — IMPORTANT: change SECRET_KEY before deploying to production
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# RSSHub
RSSHUB_URL=http://rsshub:1200

# VAPID (Web Push)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=admin@example.com

# SMTP (Email notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@juflow.app
